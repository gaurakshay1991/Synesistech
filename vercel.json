{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --no-audit --no-fund",
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/ai.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/api/public/analyze", "dest": "/api/ai.js" },
    { "src": "/api/public/ask", "dest": "/api/ai.js" },
    { "src": "/api/health/ai(?:/.*)?", "dest": "/api/ai.js" },
    { "src": "/api(?:/.*)?", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
