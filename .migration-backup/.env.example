# LIVE SYNESIS local/private environment
NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:5173

# OpenAI - store the real key only in a private local/deployment environment
OPENAI_API_KEY=paste_your_openai_project_key_here
OPENAI_MODEL=gpt-5-mini

# MVP persistence. Replace with approved database/object storage for institutional deployment.
DATA_FILE=server/data/live-synesis-store.json
MAX_UPLOAD_MB=25

# Private role-based login credentials. Replace all demo passwords before sharing.
JWT_SECRET=replace_with_a_very_long_random_secret
ADMIN_EMAIL=admin@synesis.local
ADMIN_PASSWORD=ChangeThisAdminPassword123!
LEGAL_EMAIL=legal@synesis.local
LEGAL_PASSWORD=LegalDemoOnly123!
COMPLIANCE_EMAIL=compliance@synesis.local
COMPLIANCE_PASSWORD=ComplianceDemoOnly123!
KYC_EMAIL=kyc@synesis.local
KYC_PASSWORD=KycDemoOnly123!
MANAGEMENT_EMAIL=management@synesis.local
MANAGEMENT_PASSWORD=ManagementDemoOnly123!
