{
  "name": "live-synesis-platform",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm --workspace server run dev\" \"npm --workspace client run dev\"",
    "start": "npm --workspace server start",
    "build": "npm --workspace client run build",
    "test": "npm --workspace server test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
