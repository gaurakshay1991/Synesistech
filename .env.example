# LIVE SYNESIS local/private environment
NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# OpenAI - store the real key only in Replit Secrets or another approved secret manager.
OPENAI_API_KEY=set_in_secret_manager
OPENAI_MODEL=gpt-5-mini

# MVP persistence. Replace with an approved database and object storage for institutional deployment.
DATA_FILE=server/data/live-synesis-store.json
MAX_UPLOAD_MB=25

# Keep these values stable. Changing the data key makes previously encrypted source text unreadable.
JWT_SECRET=set_a_long_random_value_in_secret_manager
DATA_ENCRYPTION_KEY=set_a_different_long_random_value_in_secret_manager

# Private role-based login configuration. Set passwords only in the secret manager.
ADMIN_EMAIL=admin@synesis.local
ADMIN_PASSWORD=set_in_secret_manager
LEGAL_EMAIL=legal@synesis.local
LEGAL_PASSWORD=set_in_secret_manager
COMPLIANCE_EMAIL=compliance@synesis.local
COMPLIANCE_PASSWORD=set_in_secret_manager
KYC_EMAIL=kyc@synesis.local
KYC_PASSWORD=set_in_secret_manager
MANAGEMENT_EMAIL=management@synesis.local
MANAGEMENT_PASSWORD=set_in_secret_manager
