# Synesis private investor mode
NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:5173

# OpenAI - never commit your real key
OPENAI_API_KEY=paste_your_openai_project_key_here
OPENAI_MODEL=gpt-5.5
ENABLE_WEB_SEARCH=true

# Database - set this only in private deployment/local environment
DATABASE_URL=paste_your_private_postgres_connection_string_here

# Private login credentials - change before investor demo
JWT_SECRET=replace_with_a_very_long_random_secret
ADMIN_EMAIL=admin@synesis.local
ADMIN_PASSWORD=ChangeThisAdminPassword123!
INVESTOR_EMAIL=investor@synesis.local
INVESTOR_PASSWORD=InvestorDemoOnly123!
REVIEWER_EMAIL=reviewer@synesis.local
REVIEWER_PASSWORD=ReviewerDemoOnly123!

PRIVATE_INVESTOR_MODE=true
PAYMENTS_ENABLED=false
MAX_UPLOAD_MB=25
