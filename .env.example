# LIVE SYNESIS production environment
NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
SYNESIS_PUBLIC_MODE=true

# Neon Postgres (use the pooled TLS connection string in production)
DATABASE_URL=set_in_secret_manager
SYNESIS_ORGANIZATION_NAME=Synesis
SYNESIS_ORGANIZATION_SLUG=synesis

# OpenAI
OPENAI_API_KEY=set_in_secret_manager
OPENAI_MODEL=gpt-5.6-terra

# Local-only fallback when DATABASE_URL is intentionally absent
DATA_FILE=server/data/live-synesis-store.json
MAX_UPLOAD_MB=15

# Keep these values stable. Changing the data key makes previously encrypted text unreadable.
JWT_SECRET=set_a_long_random_value_in_secret_manager
DATA_ENCRYPTION_KEY=set_a_different_long_random_value_in_secret_manager

# First administrator. Created only when it does not already exist.
BOOTSTRAP_ADMIN_NAME=Akshay Gaur
BOOTSTRAP_ADMIN_EMAIL=adv.akshaygaur@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=set_in_secret_manager
