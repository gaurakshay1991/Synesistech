{
  "name": "synesis-institutional-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace server run dev\" \"npm --workspace client run dev\"",
    "start": "npm --workspace server start",
    "build": "npm --workspace client run build",
    "test": "npm --workspace server test",
    "check": "npm test && npm run build",
    "db:migrate": "npm --workspace server run db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
